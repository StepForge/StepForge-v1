<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <gradient
                android:angle="135"
                android:startColor="#FF151A22"
                android:endColor="#FF0F1319"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <stroke
                android:width="1dp"
                android:color="#22FFFFFF"/>
        </shape>
    </item>

</layer-list>